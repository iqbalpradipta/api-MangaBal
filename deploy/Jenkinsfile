pipeline {
    agent any

    triggers {
        githubPush()
    }

    environment {
        TARGET_PATH = '~/api-MangaBal'
        DOMAIN = 'manga.iqbalpradipta.my.id'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Test') {
            parallel {
                stage('Backend') {
                    steps {
                        dir('backend') {
                            sh 'go vet ./...'
                            sh 'go test ./... -v -count=1'
                        }
                    }
                }

                stage('Python') {
                    steps {
                        sh 'python3 -m compileall scripts manga_source'
                    }
                }

                stage('Dashboard') {
                    steps {
                        dir('dashboard') {
                            sh 'npm ci'
                            sh 'npm run build'
                        }
                    }
                }
            }
        }

        stage('Deploy') {
            steps {
                withCredentials([
                    string(credentialsId: 'target-host', variable: 'TARGET_HOST'),
                    sshUserPrivateKey(credentialsId: 'target-host-ssh', keyFileVariable: 'SSH_KEY')
                ]) {
                    sh '''
                        TMP_SSH_KEY="$(mktemp)"
                        cp "${SSH_KEY}" "${TMP_SSH_KEY}"
                        chmod 600 "${TMP_SSH_KEY}"
                        trap 'rm -f "${TMP_SSH_KEY}"' EXIT

                        ssh -i "${TMP_SSH_KEY}" -o StrictHostKeyChecking=no ${TARGET_HOST} "mkdir -p ${TARGET_PATH}"

                        rsync -avz --delete \
                            -e "ssh -i ${TMP_SSH_KEY} -o StrictHostKeyChecking=no" \
                            --exclude=.git \
                            --exclude=__pycache__ \
                            --exclude=*.pyc \
                            --exclude=*.exe \
                            --exclude=.env \
                            --exclude=backend/.env \
                            --exclude=deploy/.env.production \
                            ./ ${TARGET_HOST}:${TARGET_PATH}/

                        ssh -i "${TMP_SSH_KEY}" -o StrictHostKeyChecking=no ${TARGET_HOST} "cd ${TARGET_PATH}/deploy && bash scripts/deploy.sh"
                        ssh -i "${TMP_SSH_KEY}" -o StrictHostKeyChecking=no ${TARGET_HOST} "sudo ln -sf ${TARGET_PATH}/deploy/nginx/manga-api.conf /etc/nginx/sites-enabled/manga-api && sudo nginx -t && sudo systemctl reload nginx"
                    '''
                }
            }
        }

        stage('Verify') {
            steps {
                withCredentials([
                    string(credentialsId: 'target-host', variable: 'TARGET_HOST'),
                    sshUserPrivateKey(credentialsId: 'target-host-ssh', keyFileVariable: 'SSH_KEY')
                ]) {
                    sh '''
                        TMP_SSH_KEY="$(mktemp)"
                        cp "${SSH_KEY}" "${TMP_SSH_KEY}"
                        chmod 600 "${TMP_SSH_KEY}"
                        trap 'rm -f "${TMP_SSH_KEY}"' EXIT

                        sleep 10
                        ssh -i "${TMP_SSH_KEY}" -o StrictHostKeyChecking=no ${TARGET_HOST} "curl -fsS http://localhost:8001/api/v1/health && echo 'Manga API OK' || (cd ${TARGET_PATH}/deploy && docker compose ps && docker logs --tail=200 manga-api && exit 1)"
                        ssh -i "${TMP_SSH_KEY}" -o StrictHostKeyChecking=no ${TARGET_HOST} "curl -fsS -o /dev/null http://localhost:3001 && echo 'Dashboard OK' || (cd ${TARGET_PATH}/deploy && docker logs --tail=50 manga-dashboard)"
                        ssh -i "${TMP_SSH_KEY}" -o StrictHostKeyChecking=no ${TARGET_HOST} "curl --http1.1 -fsS -o /dev/null https://${DOMAIN}/api/v1/health && echo 'Nginx HTTPS API OK' || (sudo nginx -T 2>/dev/null | grep -A40 -B5 '${DOMAIN}' || true; sudo tail -n 120 /var/log/nginx/error.log || true; exit 1)"
                    '''
                }
            }
        }
    }

    post {
        failure {
            echo 'Deployment failed. Check Jenkins logs for details.'
        }
    }
}
