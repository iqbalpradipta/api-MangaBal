# ===== Manga API Backend =====
APP_PORT=8001
APP_ENV=production
APP_NAME=Manga API
FRONTEND_ORIGIN=https://manga.iqbalpradipta.my.id

DB_HOST=host.docker.internal
DB_PORT=5432
DB_USER=postgres
DB_PASS=<your-db-password>
DB_NAME=db_manga
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Jakarta

# ===== Redis Cache =====
REDIS_ENABLED=true
REDIS_ADDR=host.docker.internal:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PUBLIC_CACHE_TTL_SECONDS=60

# ===== Admin / Internal Auth =====
ADMIN_TOKEN=<generate-random-admin-token>
INGEST_INTERNAL_TOKEN=<generate-random-internal-token>

# ===== Python Ingest =====
PYTHON_BIN=python3
INGEST_ALL_SCRIPT=/app/scripts/ingest_all.py
INGEST_SERIES_SCRIPT=/app/scripts/ingest_series.py
INGEST_API_BASE_URL=https://manga.iqbalpradipta.my.id/api/v1
INGEST_MAX_PARALLEL_JOBS=1
INGEST_POLL_INTERVAL_SECONDS=5
INGEST_MAX_SERIES=
INGEST_MAX_CHAPTERS=

# ===== BalStorage =====
BALSTORAGE_BASE_URL=https://storage.iqbalpradipta.my.id/api/v1
BALSTORAGE_EMAIL=<balstorage-email>
BALSTORAGE_PASSWORD=<balstorage-password>
BALSTORAGE_ROOT_FOLDER_NAME=Manga
